{
  "name": "sentaurus-tcad-syntax",
  "displayName": "Sentaurus TCAD Syntax",
  "description": "Syntax highlighting for Sentaurus TCAD files",
  "version": "2.2.2",
  "publisher": "onegayi",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ONEGAYI/sentaurus-syntax-highlight.git"
  },
  "main": "./src/extension.js",
  "activationEvents": [
    "onLanguage:sde",
    "onLanguage:sdevice",
    "onLanguage:sdevicepar",
    "onLanguage:sprocess",
    "onLanguage:emw",
    "onLanguage:inspect",
    "onLanguage:svisual",
    "onCommand:sentaurus.openHelp"
  ],
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "sde",
        "aliases": [
          "Sentaurus Structure Editor",
          "SDE"
        ],
        "extensions": [
          ".scm"
        ],
        "filenames": [],
        "filenamePatterns": [
          "*_dvs.cmd"
        ],
        "configuration": "./language-configurations/sde.json"
      },
      {
        "id": "sdevice",
        "aliases": [
          "Sentaurus Device",
          "SDEVICE"
        ],
        "extensions": [],
        "filenames": [],
        "filenamePatterns": [
          "*_des.cmd"
        ],
        "configuration": "./language-configurations/tcl.json"
      },
      {
        "id": "sdevicepar",
        "aliases": [
          "Sentaurus Device Parameter",
          "SDEVICE PAR"
        ],
        "extensions": [
          ".par"
        ],
        "filenames": [],
        "filenamePatterns": [],
        "configuration": "./language-configurations/tcl.json"
      },
      {
        "id": "sprocess",
        "aliases": [
          "Sentaurus Process",
          "SPROCESS"
        ],
        "extensions": [
          ".fps"
        ],
        "filenames": [],
        "filenamePatterns": [
          "*_fps.cmd"
        ],
        "configuration": "./language-configurations/tcl.json"
      },
      {
        "id": "emw",
        "aliases": [
          "Sentaurus EMW",
          "EMW"
        ],
        "extensions": [],
        "filenames": [],
        "filenamePatterns": [
          "*_eml.cmd",
          "*_emw.cmd"
        ],
        "configuration": "./language-configurations/tcl.json"
      },
      {
        "id": "inspect",
        "aliases": [
          "Sentaurus Inspect",
          "INSPECT"
        ],
        "extensions": [],
        "filenames": [],
        "filenamePatterns": [
          "*_ins.cmd"
        ],
        "configuration": "./language-configurations/tcl.json"
      },
      {
        "id": "svisual",
        "aliases": [
          "Sentaurus Visual",
          "SVISUAL"
        ],
        "extensions": [
          ".tcl"
        ],
        "filenames": [],
        "filenamePatterns": [
          "*_vis.tcl"
        ],
        "configuration": "./language-configurations/tcl.json"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "userFunctionCall",
        "superType": "function",
        "description": "%semanticToken.userFunctionCall%"
      },
      {
        "id": "sectionName",
        "superType": "keyword",
        "description": "%semanticToken.sectionName%"
      },
      {
        "id": "sectionKeyword",
        "superType": "type",
        "description": "%semanticToken.sectionKeyword%"
      },
      {
        "id": "subSection",
        "superType": "keyword",
        "description": "%semanticToken.subSection%"
      },
      {
        "id": "ppMacro",
        "superType": "keyword",
        "description": "%semanticToken.macro%"
      }
    ],
    "semanticTokenModifiers": [
      {
        "id": "declaration",
        "description": "%semanticModifier.declaration%"
      }
    ],
    "grammars": [
      {
        "language": "sde",
        "scopeName": "source.sentaurus.sde",
        "path": "./syntaxes/sde.tmLanguage.json"
      },
      {
        "language": "sdevice",
        "scopeName": "source.sentaurus.sdevice",
        "path": "./syntaxes/sdevice.tmLanguage.json"
      },
      {
        "language": "sdevicepar",
        "scopeName": "source.sentaurus.sdevicepar",
        "path": "./syntaxes/sdevicepar.tmLanguage.json"
      },
      {
        "language": "sprocess",
        "scopeName": "source.sentaurus.sprocess",
        "path": "./syntaxes/sprocess.tmLanguage.json"
      },
      {
        "language": "emw",
        "scopeName": "source.sentaurus.emw",
        "path": "./syntaxes/emw.tmLanguage.json"
      },
      {
        "language": "inspect",
        "scopeName": "source.sentaurus.inspect",
        "path": "./syntaxes/inspect.tmLanguage.json"
      },
      {
        "language": "svisual",
        "scopeName": "source.sentaurus.svisual",
        "path": "./syntaxes/svisual.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "sentaurus.insertSnippet",
        "title": "%sentaurus.insertSnippet%"
      },
      {
        "command": "sentaurus.scheme2infix",
        "title": "%sentaurus.scheme2infix%"
      },
      {
        "command": "sentaurus.infix2scheme",
        "title": "%sentaurus.infix2scheme%"
      },
      {
        "command": "sentaurus.exprHelp",
        "title": "%sentaurus.exprHelp%"
      },
      {
        "command": "sentaurus.testTclWasm",
        "title": "%sentaurus.testTclWasm%"
      },
      {
        "command": "sentaurus.addEnvironmentVariables",
        "title": "%sentaurus.addEnvironmentVariables%"
      },
      {
        "command": "sentaurus.removeEnvironmentVariables",
        "title": "%sentaurus.removeEnvironmentVariables%"
      },
      {
        "command": "sentaurus.exportEnvironmentVariables",
        "title": "%sentaurus.exportEnvironmentVariables%"
      },
      {
        "command": "sentaurus.importEnvironmentVariables",
        "title": "%sentaurus.importEnvironmentVariables%"
      },
      {
        "command": "sentaurus.openHelp",
        "title": "%sentaurus.openHelp%"
      }
    ],
    "snippets": [
      {
        "language": "sde",
        "path": "./snippets/sde.json"
      },
      {
        "language": "sdevice",
        "path": "./snippets/sdevice.json"
      },
      {
        "language": "sprocess",
        "path": "./snippets/sprocess.json"
      },
      {
        "language": "emw",
        "path": "./snippets/emw.json"
      },
      {
        "language": "inspect",
        "path": "./snippets/inspect.json"
      },
      {
        "language": "svisual",
        "path": "./snippets/svisual.json"
      },
      {
        "language": "sdevicepar",
        "path": "./snippets/sdevicepar.json"
      }
    ],
    "configuration": [
      {
        "title": "%config.title.syntax%",
        "properties": {
          "sentaurus.snippetPrefixes.RW": {
            "type": "string",
            "default": "RW.",
            "description": "%config.RW.desc%",
            "markdownDescription": "%config.RW.mdDesc%",
            "order": 1
          },
          "sentaurus.snippetPrefixes.DC": {
            "type": "string",
            "default": "DC.",
            "description": "%config.DC.desc%",
            "markdownDescription": "%config.DC.mdDesc%",
            "order": 2
          },
          "sentaurus.snippetPrefixes.CPP": {
            "type": "string",
            "default": "CPP.",
            "description": "%config.CPP.desc%",
            "markdownDescription": "%config.CPP.mdDesc%",
            "order": 3
          },
          "sentaurus.snippetPrefixes.CPM": {
            "type": "string",
            "default": "CPM.",
            "description": "%config.CPM.desc%",
            "markdownDescription": "%config.CPM.mdDesc%",
            "order": 4
          },
          "sentaurus.snippetPrefixes.GAUSS": {
            "type": "string",
            "default": "GAUSS.",
            "description": "%config.GAUSS.desc%",
            "markdownDescription": "%config.GAUSS.mdDesc%",
            "order": 5
          },
          "sentaurus.snippetPrefixes.IMP": {
            "type": "string",
            "default": "IMP.",
            "description": "%config.IMP.desc%",
            "markdownDescription": "%config.IMP.mdDesc%",
            "order": 6
          },
          "sentaurus.snippetPrefixes.SM": {
            "type": "string",
            "default": "SM.",
            "description": "%config.SM.desc%",
            "markdownDescription": "%config.SM.mdDesc%",
            "order": 7
          },
          "sentaurus.snippetPrefixes.PSM": {
            "type": "string",
            "default": "PSM.",
            "description": "%config.PSM.desc%",
            "markdownDescription": "%config.PSM.mdDesc%",
            "order": 8
          },
          "sentaurus.snippetPrefixes.RS": {
            "type": "string",
            "default": "RS.",
            "description": "%config.RS.desc%",
            "markdownDescription": "%config.RS.mdDesc%",
            "order": 9
          },
          "sentaurus.snippetPrefixes.RP": {
            "type": "string",
            "default": "RP.",
            "description": "%config.RP.desc%",
            "markdownDescription": "%config.RP.mdDesc%",
            "order": 10
          },
          "sentaurus.definitionMaxWidth": {
            "type": "number",
            "default": 60,
            "minimum": 0,
            "maximum": 200,
            "description": "%config.definitionMaxWidth.description%",
            "order": 11
          }
        }
      },
      {
        "title": "%config.title.envVars%",
        "properties": {
          "sentaurus.environmentVariables": {
            "type": "object",
            "default": {},
            "markdownDescription": "%config.envVars.mdDesc%",
            "additionalProperties": {
              "type": "string"
            },
            "scope": "resource",
            "order": 1
          }
        }
      },
      {
        "title": "%config.title.par%",
        "properties": {
          "sentaurus.materialDbPath": {
            "type": "string",
            "default": "",
            "description": "%config.materialDbPath.description%",
            "markdownDescription": "%config.materialDbPath.mdDesc%",
            "scope": "machine",
            "order": 1
          }
        }
      }
    ],
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "[*Dark*]": {
          "textMateRules": [
            {
              "scope": "support.constant.unit",
              "settings": {
                "foreground": "#CE9178"
              }
            },
            {
              "scope": "entity.name.variable.environment.tcl",
              "settings": {
                "fontStyle": "bold"
              }
            }
          ]
        },
        "[*Light*]": {
          "textMateRules": [
            {
              "scope": "support.constant.unit",
              "settings": {
                "foreground": "#D73A49"
              }
            },
            {
              "scope": "entity.name.variable.environment.tcl",
              "settings": {
                "fontStyle": "bold"
              }
            }
          ]
        }
      }
    },
    "semanticTokenScopes": [
      {
        "language": "sdevice",
        "scopes": {
          "sectionName": [
            "keyword.control.sdevice"
          ],
          "sectionKeyword": [
            "entity.name.tag.sdevice"
          ],
          "subSection": [
            "entity.name.type.sdevice"
          ],
          "ppMacro": [
            "entity.name.type.sdevice"
          ],
          "userFunctionCall": [
            "entity.name.function.sdevice"
          ],
          "environmentVariable": [
            "entity.name.variable.environment.tcl"
          ]
        }
      },
      {
        "language": "sprocess",
        "scopes": {
          "userFunctionCall": [
            "entity.name.function.sprocess"
          ],
          "ppMacro": [
            "entity.name.type.sprocess"
          ],
          "environmentVariable": [
            "entity.name.variable.environment.tcl"
          ]
        }
      },
      {
        "language": "emw",
        "scopes": {
          "userFunctionCall": [
            "entity.name.function.emw"
          ],
          "ppMacro": [
            "entity.name.type.emw"
          ],
          "environmentVariable": [
            "entity.name.variable.environment.tcl"
          ]
        }
      },
      {
        "language": "inspect",
        "scopes": {
          "userFunctionCall": [
            "entity.name.function.inspect"
          ],
          "ppMacro": [
            "entity.name.type.inspect"
          ],
          "environmentVariable": [
            "entity.name.variable.environment.tcl"
          ]
        }
      },
      {
        "language": "svisual",
        "scopes": {
          "userFunctionCall": [
            "entity.name.function.svisual"
          ],
          "ppMacro": [
            "entity.name.type.svisual"
          ],
          "environmentVariable": [
            "entity.name.variable.environment.tcl"
          ]
        }
      },
      {
        "language": "sdevicepar",
        "scopes": {
          "userFunctionCall": [
            "entity.name.function.sdevicepar"
          ],
          "ppMacro": [
            "entity.name.type.sdevicepar"
          ],
          "environmentVariable": [
            "entity.name.variable.environment.tcl"
          ]
        }
      }
    ]
  },
  "dependencies": {
    "web-tree-sitter": "^0.25.3"
  }
}
