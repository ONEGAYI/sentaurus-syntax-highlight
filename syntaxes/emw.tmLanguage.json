{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Sentaurus EMW",
  "patterns": [
    {
      "match": "\\b(CodeVExcitation|PECMedia|Detector|RTA|Acceleware|Monitor|Plot|DFT|TruncatedPlaneWaveExcitation|Sensor|Farfield|Globals|PMCMedia|Save|GaussianBeamExcitation|Extractor|DispersiveMedia|PlaneWaveExcitation|ComplexRefractiveIndex|Boundary)(?![A-Za-z0-9_:-])",
      "name": "keyword.control.emw"
    },
    {
      "patterns": [
        {
          "match": "\\b(SigmaMax|PolarCutRange|Tolerance|BeamPower|Polarization|Model|DeltaK|EllipticalPolarizationMagnitude|PhaseShift|OrderKappa|DownSampling|GridFile|NumericalAperture|PolarizationAngle|Location|TemperatureDep|BreakOnError|Sides|FailureOnUnreachedTolerance|LogFilePrefix|Sensors|NumberOfThreads|PlaneX|BoxCorner2|WavelengthPrecision|FieldDataFile|Mode|EndTick|PolarRange|ResultFile)\\b",
          "name": "constant.numeric.emw"
        },
        {
          "match": "\\b(StepZ|StartTick|InterfaceAveraging|AlphaProfile|OrderAlpha|ExcludeMaterial|ScatteredFieldOnly|Frequency|ParameterFile|PlaneZ|OverSampling|KappaMax|AlphaMax|CRIModel|Log|PlaneY|Extrapolate|MinWavelength|Amplitude|Axis|ExcludeRegion|EllipticalPolarizationPhase|ModelParameters|Field|StepY|AzimuthalCutList|BoxCorner1|Phase|AnchorPoint1|NumberOfPlaneWaves)\\b",
          "name": "constant.numeric.emw"
        },
        {
          "match": "\\b(InputDataFile|TickStep|StartTime|Theta|UnavailableLicenseAction|Thickness|Direction|DomainDecomposition|Name|Phi|AmplitudeScaling|BeamCenter|WavelengthList|LoadFile|RotationAngles|SigmaProfile|TotalSimulationTime|Delay|Signal|Domain|Region|LibraryPath|Radius|Intensity|Psi|Material|MaxWavelength|FinalPlot|Temperature|EndTime)\\b",
          "name": "constant.numeric.emw"
        },
        {
          "match": "\\b(BeamRadius|GainDep|AzimuthalCutRange|AnchorPoint2|PolarCutList|IgnoreMaterials|TimeStep|WriteBehavior|ParallelLicenses|LogFile|StepX|IntegrationRange|CompressTDR|BoxDimensions|BoxCenter|Domains|KappaProfile|NRise|Quantity|WavelengthDep|OrderSigma|WavelengthRange|OutputFilePrefix|TdrNativeTensorGridUnit|LogLevel|CarrierDep|AzimuthalRange|PartialCoherenceFactor|CoordinateTransformation|TotalTimeSteps)\\b",
          "name": "constant.numeric.emw"
        },
        {
          "match": "\\b(Sigma|Type|Interpolation|CRIMIPath|LogPrecision|ArraySize|NumberOfWavelengths|Wavelength)\\b",
          "name": "constant.numeric.emw"
        }
      ]
    },
    {
      "patterns": [
        {
          "match": "\\b(ImagMagneticFieldZ|ImagElectricFieldZ|Dfgeo|PeriodicOblique|Homogeneous|SingleDipoleDrude|Numbered|AbsElectricDisplacement|um|ImagElectricFieldY|MixedElement|TFSF|IncoherentImagEy|Local|Auto|m|Mur|RelativePermittivityYY|serial|Intersecting|Hybrid|CplxMagneticField|SingleDipoleDebye|IncoherentImagEz|OverwriteAndNumbered|ElectricConductivityZZ|TM|ElectricConductivityYY|DrudeModLorentz|RealLin)\\b",
          "name": "string.quoted.emw"
        },
        {
          "match": "\\b(Higdon|TE|reduce|IncoherentRealEz|Decayed|CplxElectricField|PMC|No|CplxEMField|SMP|RelativePermeabilityZZ|RelativePermittivityZZ|Harmonic|ElectricFieldIntensity|all|Synopsys|RealElectricFieldZ|RelativePermeabilityYY|Separate|RealElectricFieldY|DrudeLorentz|AbsorbedPhotonDensity|IncoherentRealHx|ASCII|Gauss|Z|cplxRefIndex|All|global|maxcomp)\\b",
          "name": "string.quoted.emw"
        },
        {
          "match": "\\b(RealMagneticField|MagneticConductivityZZ|AbsElectricField|AbsMagneticInduction|United|CplxExtCoeffXX|AbsMagneticField|PEC|IncoherentRealEy|Zmin|Inhomogeneous|E|IncoherentRealHz|MagneticConductivityYY|CPML|max|Automatic|PlaneWave|UserDefined|Real|Integrate|ijk|RelativePermeabilityXX|IncoherentImagHy|PhotonFluxDensity|l2scaled|Xmax|Acceleware|Tnorm|CodeV)\\b",
          "name": "string.quoted.emw"
        },
        {
          "match": "\\b(Volume|IncoherentOpticalGeneration|Debye|ConductionCurrentDensity|IncoherentImagEx|IncoherentRealHy|Y|Hard|CplxRefIndexZZ|cplxExtCoeff|Yes|Xmin|Lorentz|ImagElectricFieldX|IncoherentImagHx|ComputeFromComplexRefractiveIndex|Software|CplxRefIndexXX|Unified|UseCRI|Target|ImagMagneticFieldX|Anorm|MPI|Region|Global|ImagMagneticFieldY|CplxExtCoeffZZ|IncoherentRealEx|H)\\b",
          "name": "string.quoted.emw"
        },
        {
          "match": "\\b(GaussianBeam|Transient|IncoherentIntensity|Tensor|Ymin|none|RealMagneticFieldY|RelativePermittivityXX|Zmax|PointSource|Rnorm|Simple|RaiseError|RealElectricFieldX|BackwardCompatibility|Average|TimeAveraged|Default|PoyntingVectorSurfaceIntegral|fromTop|Ymax|min|AbsorbedPowerDensity|ImagMagneticField|Binary|Bulk|RTA|ModLorentz|maxmag|xyz)\\b",
          "name": "string.quoted.emw"
        },
        {
          "match": "\\b(fromBottom|RealMagneticFieldZ|T|IncoherentAbsorbedPhotonDensity|Overwrite|l2|abort|FromFile|RealLog|PowerFluxDensity|Maximum|Source|MagneticConductivityXX|IncoherentImagHz|RealElectricField|RealMagneticFieldX|ImagElectricField|X|CplxExtCoeffYY|A|Periodic|OpticalGeneration|wait|R|ElectricConductivityXX|Imag|CplxRefIndexYY|Conservative|Hardware|Surface)\\b",
          "name": "string.quoted.emw"
        },
        {
          "match": "\\b(Standard|TruncatedPlaneWave|Profile|Dfise|Drude)\\b",
          "name": "string.quoted.emw"
        }
      ]
    },
    {
      "name": "meta.preprocessor.define.tcl",
      "match": "^\\s*(#define)\\b\\s+(\\w+)(\\s+.*)?$",
      "captures": {
        "1": { "name": "keyword.control.preprocessor.tcl" },
        "2": { "name": "entity.name.type.tcl" },
        "3": {
          "patterns": [
            { "match": "\"[^\"]*\"", "name": "string.quoted.double.tcl" },
            { "match": "\\b(defined|TRUE|FALSE)\\b", "name": "keyword.control.preprocessor.tcl" }
          ]
        }
      }
    },
    {
      "name": "meta.preprocessor.undef.tcl",
      "match": "^\\s*(#undef)\\b\\s+(\\w+)",
      "captures": {
        "1": { "name": "keyword.control.preprocessor.tcl" },
        "2": { "name": "entity.name.type.tcl" }
      }
    },
    {
      "name": "meta.preprocessor.ifdef.tcl",
      "match": "^\\s*(#(?:ifdef|ifndef))\\b\\s+(\\w+)",
      "captures": {
        "1": { "name": "keyword.control.preprocessor.tcl" },
        "2": { "name": "entity.name.type.tcl" }
      }
    },
    {
      "name": "meta.preprocessor.other.tcl",
      "match": "^\\s*(#(?:if|elif|else|endif|include|error|set))\\b(.*$)",
      "captures": {
        "1": { "name": "keyword.control.preprocessor.tcl" },
        "2": {
          "patterns": [
            { "match": "\\b(defined|TRUE|FALSE)\\b", "name": "keyword.control.preprocessor.tcl" },
            { "match": "\"[^\"]*\"", "name": "string.quoted.double.tcl" }
          ]
        }
      }
    },
    {
      "match": "\\b([A-Z][A-Z0-9_]{2,}|_[A-Z0-9_]+)\\b",
      "name": "entity.name.type.tcl"
    },
    {
      "name": "comment.line.hash",
      "match": "#.*$"
    },
    {
      "name": "comment.line.asterisk",
      "match": "^\\s*\\*.*$"
    },
    {
      "name": "string.quoted.double",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape",
          "match": "\\\\."
        },
        {
          "name": "meta.interpolation.tcl",
          "begin": "\\[",
          "end": "\\]",
          "captures": {
            "0": { "name": "punctuation.section.interpolation.tcl" }
          },
          "patterns": [
            { "include": "$self" }
          ]
        },
        {
          "match": "\\$\\{[^}]+\\}|\\$[A-Za-z_][A-Za-z0-9_:]*",
          "name": "variable.other.readwrite.tcl"
        },
        {
          "match": "@[a-zA-Z_<][^@]*@",
          "name": "constant.character.format.placeholder"
        }
      ]
    },
    {
      "match": "\\b(\\d+\\.?\\d*|\\.\\d+)([eE][+-]?\\d+)?\\b",
      "name": "constant.numeric"
    },
    {
      "match": "@[a-zA-Z_<][^@]*@",
      "name": "constant.character.format.placeholder"
    },
    {
      "match": "\\b(if|else|elseif|for|foreach|while|switch|break|continue|return)\\b",
      "name": "keyword.control.emw"
    },
    {
      "match": "\\b(proc)\\s+([A-Za-z_][A-Za-z0-9_\\-]*)",
      "captures": {
        "1": { "name": "keyword.other.emw" },
        "2": { "name": "entity.name.function.emw" }
      }
    },
    {
      "match": "\\b(proc|try|throw)\\b",
      "name": "keyword.other.emw"
    },
    {
      "match": "\\b(string)\\s+(length|match|range|first|last|index|trim|trimleft|trimright|tolower|toupper|totitle|equal|compare|is|map|repeat|replace|reverse|cat|wordstart|wordend|bytelength)\\b",
      "captures": {
        "1": { "name": "support.function.emw" },
        "2": { "name": "support.type.tcl-subcommand" }
      }
    },
    {
      "match": "\\b(file)\\s+(join|dirname|tail|extension|rootname|exists|isfile|isdirectory|mkdir|copy|delete|rename|nativename|normalize|stat|size|readable|writable|executable|mtime|atime|type)\\b",
      "captures": {
        "1": { "name": "support.function.emw" },
        "2": { "name": "support.type.tcl-subcommand" }
      }
    },
    {
      "match": "\\b(info)\\s+(exists|commands|procs|args|body|level|script|hostname|patchlevel|tclversion|globals|locals|vars|default)\\b",
      "captures": {
        "1": { "name": "support.function.emw" },
        "2": { "name": "support.type.tcl-subcommand" }
      }
    },
    {
      "match": "\\b(array)\\s+(exists|get|set|names|size|unset|statistics)\\b",
      "captures": {
        "1": { "name": "support.function.emw" },
        "2": { "name": "support.type.tcl-subcommand" }
      }
    },
    {
      "match": "\\b(dict)\\s+(create|get|set|exists|unset|remove|replace|merge|keys|values|size|for|map|filter|info|update|with)\\b",
      "captures": {
        "1": { "name": "support.function.emw" },
        "2": { "name": "support.type.tcl-subcommand" }
      }
    },
    {
      "match": "\\b(after|append|array|break|catch|cd|close|concat|continue|error|eval|exec|exit|expr|file|flush|for|foreach|format|gets|glob|global|if|incr|info|join|lappend|lassign|lindex|linsert|list|llength|lmap|lrange|lrepeat|lreplace|lreverse|lsearch|lset|lsort|open|proc|puts|pwd|read|regexp|regsub|rename|return|scan|set|source|split|string|subst|switch|throw|time|try|unset|update|uplevel|upvar|variable|vwait|while)\\b",
      "name": "support.function.emw"
    },
    {
      "match": "\\b(abs|acos|asin|atan|atan2|bool|ceil|cos|cosh|double|entier|exp|floor|fmod|hypot|int|isqrt|log|log10|max|min|pow|rand|round|sin|sinh|sqrt|srand|tan|tanh|wide)\\b",
      "name": "support.function.math.tcl"
    },
    {
      "match": "\\$\\{[^}]+\\}|\\$[A-Za-z_][A-Za-z0-9_:]*",
      "name": "variable.other.readwrite.tcl"
    },
    {
      "match": "\\b[A-Za-z_][A-Za-z0-9_\\-]*(?![A-Za-z0-9_\\-])",
      "name": "variable.other"
    }
  ],
  "repository": {},
  "scopeName": "source.sentaurus.emw"
}
