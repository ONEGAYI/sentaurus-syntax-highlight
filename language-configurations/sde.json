{
  "comments": {
    "lineComment": ";"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*\\{[^}\"']*$|^.*\\([^)\"']*$",
    "decreaseIndentPattern": "^\\s*[})]"
  },
  "onEnterRules": [
    {
      "beforeText": "^(?!\\s*;).*\\([^)\\s][^)]*$",
      "afterText": "^\\s*\\)[\\s;]*$",
      "action": {
        "indent": "indentOutdent",
        "appendText": "\t"
      }
    }
  ]
}
